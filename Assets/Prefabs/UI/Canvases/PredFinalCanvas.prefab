  m_text: "\u0412\u044B \u0434\u043E\u0448\u043B\u0438 \u0434\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E
    \u0447\u0435\u043A\u043F\u043E\u0438\u043D\u0442\u0430, \u043F\u043E\u0432\u0435\u0441\u0435\u043B\u0438\u0442\u0435\u0441\u044C
